# 应用配置
APP_NAME=FastAPI Tutorial
APP_VERSION=1.0.0
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/fastapi_db

# JWT 配置
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# SMTP 配置 (Office 365 中国版)
SMTP_HOST=smtp.partner.outlook.cn
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=your-email@example.com
SMTP_FROM_NAME=智教云
SMTP_USE_TLS=false

# 验证码配置
VERIFICATION_CODE_EXPIRE_MINUTES=5

# AI API 配置
KIMI_API_KEY=your-kimi-api-key

# Claude API 配置（可选，用于仿真生成）
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_BASE_URL=https://xiaoai.plus/v1
CLAUDE_MODEL=claude-opus-4-5-20251101

# 仿真生成配置
# provider: "kimi" 或 "claude"，默认使用 kimi
SIMULATION_PROVIDER=kimi
SIMULATION_MODEL=moonshot-v1-128k

# 文件存储配置
STORAGE_TYPE=database
STORAGE_PATH=./storage/documents

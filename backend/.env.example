# AI 模型配置示例
# 复制此文件为 .env 并填入你的 API Keys

# ==================== 必需配置 ====================

# Kimi / Moonshot API Key（必需，当前默认模型）
KIMI_API_KEY=your-kimi-api-key-here

# ==================== 可选配置 ====================
# 以下配置用于扩展更多 AI 模型，不配置不影响现有功能

# DeepSeek API Key（推荐，性价比高）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1  # 可选，自定义代理地址

# 通义千问 API Key（可选）
# 获取地址：https://dashscope.aliyun.com/
QWEN_API_KEY=sk-your-qwen-key-here
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # 可选

# 智谱 GLM API Key（可选）
# 获取地址：https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key-here
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4  # 可选

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql://user:password@localhost:5432/fastapi_db

# ==================== JWT 配置 ====================
SECRET_KEY=your-secret-key-here

# ==================== SMTP 配置 ====================
SMTP_HOST=smtp.partner.outlook.cn
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=your-email@example.com
SMTP_FROM_NAME=智教云
